    {
        "id": "24b37a9247161702",
        "type": "function",
        "z": "cae45d3d0da42adb",
        "name": "function 2",
        "func": "let data = msg.payload;\n\nif (typeof data === \"string\") {\n    data = JSON.parse(data);\n}\n\nconst distance = data.distanceCm ?? data.distance ?? data.cm;\n\nif (distance === undefined || distance === null || isNaN(Number(distance))) {\n    node.warn({\n        error: \"Invalid distance value\",\n        receivedPayload: data\n    });\n    return null;\n}\n\nmsg.payload = Number(distance);\nmsg.topic = \"Odległość\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 160,
        "wires": [
            [
                "bf5049e9d6721bd5"
            ]
        ]
    },
