    {
        "id": "e930c1e11cf86e50",
        "type": "function",
        "z": "cae45d3d0da42adb",
        "name": "Extract DHT22 values",
        "func": "let data = msg.payload;\n\nif (typeof data === \"string\") {\n    data = JSON.parse(data);\n}\n\nconst temperature = data.temperature ?? data.temp;\nconst humidity = data.humidity;\n\nconst temperatureMsg = {\n    payload: Number(temperature),\n    topic: \"Temperatura\"\n};\n\nconst humidityMsg = {\n    payload: Number(humidity),\n    topic: \"Wilgotność\"\n};\n\nreturn [temperatureMsg, humidityMsg];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 180,
        "y": 160,
        "wires": [
            [
                "6bb1e2edee68e632"
            ],
            [
                "25f7f588b90421ab"
            ]
        ]
    },
